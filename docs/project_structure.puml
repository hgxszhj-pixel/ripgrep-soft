@startuml TurboSearch Project Structure

' ==================== 项目配置 ====================
!theme plain
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam stereotypeCBackgroundColor #LightGray

' ==================== 包定义 ====================

package "CLI模块" {
    [cli]
    [main]
}

package "核心模块" {
    [index]
    [search]
    [mft_reader]
}

package "用户界面" {
    [gui]
    [history]
}

package "基础设施" {
    [logging]
    [error]
}

' ==================== 依赖关系 ====================

' main -> gui
main --> gui

' gui -> index
gui --> index

' gui -> search
gui --> search

' gui -> history
gui --> history

' search -> index
search --> index

' index -> mft_reader
index ..> mft_reader : <<use>>

' ==================== 类图详情 ====================

package "cli" {
    class Cli {
        +command: Option<Commands>
        +verbose: bool
        +quiet: bool
        +gui: bool
    }

    enum Commands {
        Search{path, pattern, content, regex, case_sensitive, context, size}
        Index{path, max_files}
    }
}

package "index" {
    class FileEntry {
        +path: PathBuf
        +name: String
        +size: u64
        +modified: SystemTime
        +from_path(path: &Path) -> Option<Self>
    }

    class FileIndex {
        +path: PathBuf
        +modified: SystemTime
        +new() -> Self
        +add_entry(entry: FileEntry)
        +walk_directory(path: &Path) -> Result<()>
        +walk_directory_limited(path: &Path, max_files: usize) -> Result<usize>
        +save(path: &Path) -> Result<()>
        +load(path: &Path) -> Result<Self>
        +root_path() -> &Path
        +entries() -> &[FileEntry]
        +len() -> usize
    }

    function os_str_to_string(os_str: &OsStr) -> String
}

package "search" {
    class SizeFilter {
        +min_size: u64
        +max_size: u64
        +new(min: u64, max: u64) -> Self
        +from_string(s: &str) -> Option<Self>
        +from_range(s: &str) -> Option<Self>
        +matches(size: u64) -> bool
    }

    class SearchQuery {
        +pattern: String
        +case_sensitive: bool
        +regex: bool
        +offset: usize
        +limit: usize
        +size_filter: SizeFilter
    }

    class Searcher {
        +search(query: &SearchQuery, index: &FileIndex) -> Vec<&FileEntry>
        #fuzzy_search(query: &SearchQuery, index: &FileIndex) -> Vec<&FileEntry>
        #regex_search(query: &SearchQuery, index: &FileIndex) -> Vec<&FileEntry>
        #glob_search(query: &SearchQuery, index: &FileIndex) -> Vec<&FileEntry>
    }

    class ContentSearchQuery {
        +pattern: String
        +case_sensitive: bool
        +regex: bool
        +max_context: usize
        +size_filter: SizeFilter
    }

    class ContentMatch {
        +file_path: PathBuf
        +line_number: usize
        +line_content: String
        +match_text: String
    }

    class ContentSearcher {
        +search(query: &ContentSearchQuery, path: &Path) -> Vec<ContentMatch>
    }

    note right of Searcher
      使用DashMap缓存Regex
      支持模糊搜索/正则搜索/Glob搜索
    end note
}

package "mft_reader" {
    class MftFileEntry {
        +path: PathBuf
        +name: String
        +size: u64
        +is_directory: bool
    }

    class MftReader {
        +new(volume: &str) -> Result<Self>
        +read_entries() -> Result<Vec<MftFileEntry>>
    }
}

package "gui" {
    class RipgrepApp {
        +search_query: String
        +index: Arc<FileIndex>
        +search_path: PathBuf
        +displayed_results: Vec<FileEntry>
        +streaming_matches: Vec<PathBuf>
        +preview_content: String
        +is_indexing: bool
        +is_searching: bool
    }

    enum SearchMode {
        Filename
        Content
        Regex
    }

    enum AppTheme {
        Light
        Dark
    }
}

package "history" {
    class SearchHistoryEntry {
        +query: String
        +search_path: PathBuf
        +timestamp: SystemTime
        +result_count: usize
    }

    class SearchHistory {
        +entries: Vec<SearchHistoryEntry>
        +add(entry: SearchHistoryEntry)
        +get_recent(count: usize) -> Vec<SearchHistoryEntry>
        +save(path: &Path) -> Result<()>
        +load(path: &Path) -> Result<Self>
    }
}

package "logging" {
    class Logger {
        +init_logging(log_dir: Option<PathBuf>) -> Result<()>
    }
}

package "error" {
    class AppError {
        +source: String
    }
}

' ==================== 关系详情 ====================

Searcher --> SizeFilter
Searcher --> FileIndex
Searcher --> FileEntry

gui --> Searcher
gui --> ContentSearcher
gui --> SizeFilter
gui --> FileIndex
gui --> FileEntry

ContentSearcher --> ContentSearchQuery
ContentSearcher --> ContentMatch

FileIndex --> FileEntry
FileIndex --> MftReader

@enduml
