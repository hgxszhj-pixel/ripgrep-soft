@startuml TurboSearch Indexing Process

!theme plain
skinparam activity {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
    ArrowColor #2E7D32
}
skinparam startColor #4CAF50
skinparam stopColor #F44336

title TurboSearch Indexing Workflow

|User|
start
:Select Directory to Index;
:Configure Max Files;

|System|
:Create FileIndex Instance;
:Call walk_directory_limited();

|File Walker|
fork
    :WalkDir Traverses Tree;
fork again
    :Check MFT Available;
    note right: Windows only\nNTFS performance
end fork

repeat :Process Each Path;
    :Get File Metadata;
    :Create FileEntry;
    note right
      path: PathBuf
      name: String
      size: u64
      modified: SystemTime
    end note

    :Add to Entries Vec;
    :Increment Counter;

    if (Counter >= Max Files) then (yes)
        :Stop Traversal;
        break
    endif
repeat while (More Files?) is (yes)
->No;

|Index Builder|
:Update Index Metadata;
note right
  path: PathBuf
  modified: SystemTime
end note
:Return FileIndex;

|System|
:Update UI Status;
:Display Index Stats;
note right: Total files indexed

|User|
if (Save Index) then (yes)
    :Serialize to JSON;
    note right: FileIndex.save()\nserde_json
    :Write to Disk;
else (no)
    :Keep in Memory;
endif

stop

@enduml
