@startuml TurboSearch DDD Model

!theme plain
skinparam linetype ortho
skinparam rectangle {
    BackgroundColor #LightYellow
    BorderColor #Orange
}
skinparam entity {
    BackgroundColor #LightBlue
    BorderColor #Blue
}
skinparam valueobject {
    BackgroundColor #LightGreen
    BorderColor #Green
}
skinparam service {
    BackgroundColor #LightPink
    BorderColor #Red
}
skinparam aggregate {
    BackgroundColor #LightCyan
    BorderColor #DarkCyan
}

' ==================== Domain Layer ====================

package "Domain Layer\n领域层" {

    ' --- Entities ---
    entity "FileEntry\n文件实体" as FE {
        +path: PathBuf <<PK>>
        +name: String
        +size: u64
        +modified: SystemTime
    }

    entity "SearchHistoryEntry\n历史记录实体" as SHE {
        +id: UUID
        +query: String
        +search_path: PathBuf
        +timestamp: SystemTime
        +result_count: usize
    }

    entity "MftFileEntry\nMFT文件实体" as MFE {
        +sequence_num: u64 <<PK>>
        +path: PathBuf
        +name: String
        +size: u64
        +is_directory: bool
    }

    ' --- Value Objects ---
    valueobject "SizeFilter\n大小过滤器" as SF {
        +min_size: u64
        +max_size: u64
        --
        +matches(size: u64): bool
    }

    valueobject "SearchQuery\n搜索查询" as SQ {
        +pattern: String
        +case_sensitive: bool
        +regex: bool
        +offset: usize
        +limit: usize
        +size_filter: SizeFilter
    }

    valueobject "ContentSearchQuery\n内容搜索查询" as CSQ {
        +pattern: String
        +case_sensitive: bool
        +regex: bool
        +max_context: usize
        +size_filter: SizeFilter
    }

    valueobject "ContentMatch\n内容匹配" as CM {
        +file_path: PathBuf
        +line_number: usize
        +line_content: String
        +match_text: String
    }

    valueobject "SearchMode\n搜索模式" as SM {
        <<enum>>
        Filename
        Content
        Regex
    }

    valueobject "AppTheme\n应用主题" as AT {
        <<enum>>
        Light
        Dark
    }

    ' --- Aggregates ---
    aggregate "FileIndex\n文件索引" as FI {
        +path: PathBuf <<PK>>
        +modified: SystemTime
        --
        +entries: Vec<FileEntry>
    }

    aggregate "SearchHistory\n搜索历史" as SH {
        +id: UUID
        --
        +entries: Vec<SearchHistoryEntry>
    }

    aggregate "RipgrepApp\n应用根" as RA {
        +search_query: String
        +search_path: PathBuf
        +is_indexing: bool
        +is_searching: bool
    }

    ' --- Services ---
    service "Searcher\n搜索服务" as S {
        +search(query, index): Vec<&FileEntry>
    }

    service "ContentSearcher\n内容搜索服务" as CS {
        +search(query, path): Vec<ContentMatch>
    }

    service "MftReader\nMFT读取服务" as MR {
        +read_entries(): Vec<MftFileEntry>
    }

    ' --- Relationships ---
    FI "1" --> "*" FE : contains
    SH "1" --> "*" SHE : contains
    RA "1" --> "1" FI : indexes
    RA "1" --> "1" SM : uses
    RA "1" --> "1" AT : uses
    S "1" --> "1" FI : queries
    S "1" --> "1" SF : uses
    CS "1" --> "1" CSQ : uses
    CS "1" --> "1" SF : uses
    CS "1" --> "*" CM : produces
    MR "1" --> "*" MFE : reads
}

' ==================== Application Layer ====================

package "Application Layer\n应用层" as AppLayer {
    rectangle "CLI\n命令行界面" as CLI {
        +command: Commands
        +verbose: bool
        +gui: bool
    }

    rectangle "GUI\n图形界面" as GUI {
        +displayed_results: Vec<FileEntry>
        +streaming_matches: Vec<PathBuf>
        +preview_content: String
    }
}

' ==================== Infrastructure Layer ====================

package "Infrastructure Layer\n基础设施层" as InfraLayer {
    rectangle "Logging\n日志系统" as LOG {
        +init_logging()
    }

    rectangle "History Persistence\n历史持久化" as HP {
        +save()
        +load()
    }

    rectangle "Index Persistence\n索引持久化" as IP {
        +save()
        +load()
    }
}

' ==================== 层级关系 ====================

AppLayer -down-> AppLayer : uses
AppLayer -down-> InfraLayer : uses

@enduml
