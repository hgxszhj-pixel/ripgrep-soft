@startuml TurboSearch Main Process Flow

!theme plain
skinparam activity {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    ArrowColor #1976D2
}
skinparam startColor #4CAF50
skinparam stopColor #F44336
skinparam decisionColor #FF9800
skinparam forkColor #9C27B0

title TurboSearch Application Flow

start
:Application Starts;
note right: main.rs入口

if (Launch GUI?) then (yes)
    :Initialize eframe;
    :Create RipgrepApp;
    :Show Main Window;
else (no)
    :Parse CLI Args;
    :Execute Command;
    stop
endif

:User Selects Search Path;
note right: Folder selection dialog

if (Use MFT Index?) then (yes)
    :Read NTFS MFT;
    :Fast File Enumeration;
    :Create FileIndex from MFT;
else (no)
    :Walk Directory Tree;
    :Collect FileEntries;
    :Build FileIndex;
endif

:Index Ready;

:User Enters Search Query;

if (Search Mode) then (Filename)
    :Fuzzy Search Mode;
    if (Has Wildcards?) then (yes)
        :Glob to Regex;
        :Regex Search;
    else (no)
        :SkimMatcherV2 Fuzzy;
    endif
else if (Content)
    :Content Search Mode;
    :Parallel File Reading;
    :Line-by-line Match;
else (Regex)
    :Regex Search Mode;
    :Get Cached Regex;
    note right: DashMap cache\nfor performance
endif

:Filter by Size;
note right: SizeFilter\n(min/max)
:Rank Results;

:Display Results;
note right: Max 500 entries\nin UI

if (User Selects File) then (yes)
    :Preview File;
    if (Text File?) then (yes)
        :Read Content;
        :Syntax Highlight;
    else if (Binary) then (yes)
        :Show Metadata;
    endif
endif

:User Exits;
stop

@enduml
