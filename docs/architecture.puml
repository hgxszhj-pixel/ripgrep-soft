@startuml TurboSearch System Architecture

!theme plain
skinparam packageStyle rectangle
skinparam componentStyle uml2
skinparam rectangle {
    BackgroundColor #ECEFF1
    BorderColor #546E7A
    RoundCorner 8
}
skinparam interface {
    BackgroundColor #FFF8E1
    BorderColor #FF8F00
}
skinparam arrow {
    Thickness 2
    Color #263238
}

title TurboSearch System Architecture

package "Presentation Layer\n(表现层)" {
    rectangle "GUI\n(eframe/egui)" as GUI {
    }
    rectangle "CLI\n(clap)" as CLI {
    }
}

package "Application Layer\n(应用层)" {
    rectangle "RipgrepApp" as App {
    }
    rectangle "SearchService" as SearchSvc {
    }
    rectangle "IndexService" as IndexSvc {
    }
}

package "Domain Layer\n(领域层)" {
    rectangle "Searcher" as DomainSearch {
    }
    rectangle "ContentSearcher" as DomainContent {
    }
    rectangle "FileIndex" as DomainIndex {
    }
    rectangle "SizeFilter" as DomainFilter {
    }
}

package "Infrastructure Layer\n(基础设施层)" {
    rectangle "FileSystem" as FS {
    }
    rectangle "MFTReader" as MFT {
    }
    rectangle "History Persistence" as History {
    }
    rectangle "Index Persistence" as Persistence {
    }
    rectangle "Logging\n(tracing)" as Logging {
    }
}

package "External Libraries" {
    rectangle "fuzzy-matcher" as Fuzzy {
    }
    rectangle "regex" as Regex {
    }
    rectangle "dashmap" as Dashmap {
    }
    rectangle "walkdir" as Walkdir {
    }
}

' Layer relationships
GUI --> App
CLI --> App

App --> SearchSvc
App --> IndexSvc

SearchSvc --> DomainSearch
SearchSvc --> DomainContent
IndexSvc --> DomainIndex

DomainSearch --> Fuzzy
DomainSearch --> Regex
DomainSearch --> Dashmap
DomainSearch --> DomainFilter

DomainIndex --> DomainFilter
DomainIndex --> DomainEntry
DomainEntry --> FS

MFT --> DomainIndex

DomainSearch --> DomainIndex

History --> Persistence
IndexSvc --> Persistence

SearchSvc --> Logging

@enduml
